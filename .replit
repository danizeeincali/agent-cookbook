run = "npm install && npm run build && node packages/rr-node/dist/server.js"
entrypoint = "packages/rr-node/src/server.ts"
modules = ["nodejs-20", "nix"]

[env]
NODE_ID = "replit-1"
PORT = "3000"
HOST = "0.0.0.0"
DATA_DIR = "./data"
NODE_ENV = "production"

[nix]
channel = "stable-25_05"

[deployment]
run = ["node", "packages/rr-node/dist/server.js"]
build = ["sh", "-c", "npm install && npm run build"]
deploymentTarget = "autoscale"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 node packages/rr-node/dist/server.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
