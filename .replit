run = "npm install && npm run build && node packages/rr-node/dist/server.js"
entrypoint = "packages/rr-node/src/server.ts"

[env]
NODE_ID = "replit-1"
PORT = "3000"
HOST = "0.0.0.0"
DATA_DIR = "./data"
NODE_ENV = "production"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "node packages/rr-node/dist/server.js"]
build = ["sh", "-c", "npm install && npm run build"]
