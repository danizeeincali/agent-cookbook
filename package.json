{
  "name": "agent-cookbook",
  "version": "1.0.0",
  "description": "The missing infrastructure layer for AI coding agents",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "dev": "npm run dev --workspaces --if-present",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "keywords": [
    "ai-agents",
    "coding-agents",
    "distributed-registry",
    "vector-search",
    "recipes",
    "institutional-knowledge",
    "claude-code",
    "openclaw",
    "cursor",
    "devin"
  ],
  "author": "Agent Cookbook Contributors",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0"
  }
}
