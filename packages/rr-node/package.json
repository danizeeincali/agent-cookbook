{
  "name": "@agent-cookbook/node",
  "version": "1.0.0",
  "description": "R&R Node with HTTP server and cluster configuration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rr-node": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "test": "node --test"
  },
  "dependencies": {
    "@agent-cookbook/store": "*",
    "@agent-cookbook/discover": "*",
    "@agent-cookbook/receipts": "*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
